{
  "name": "cloudshelf",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:server": "bun --watch server/index.ts",
    "dev:ui": "vite",
    "dev": "concurrently -n server,ui -c blue,magenta \"bun run dev:server\" \"bun run dev:ui\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production bun server/index.ts",
    "typecheck": "tsc -b"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.95.0",
    "@tanstack/react-virtual": "^3.13.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "hono": "^4.12.23",
    "idb-keyval": "^6.2.1",
    "lucide-react": "^0.469.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.5",
    "react-hook-form": "^7.54.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-plugin": "^1.95.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
